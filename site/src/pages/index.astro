---
import "../styles/index.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,300..900;1,300..900&family=Yeseva+One&display=swap"
      rel="stylesheet"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sage & Sundry</title>
  </head>
  <body>
    <header>
      <h1>Sage & Sundry Apothecary</h1>
      <div class="current-season"><p>Summer</p></div>
    </header>
    <aside class="in-season">
      <p>Currently in season:</p>
    </aside>
    <main class="pantry">
      <p>Ingredients</p>
      <div class="active-batches"><p>Active Batches</p></div>
    </main>
  </body>
</html>
